{
"name": "otaku-clash-angola-backend",
"version": "1.0.0",
"description": "Enterprise-grade backend para plataforma Otaku Clash Angola - Anime Quiz, Battle Royale, Torneios, Ranking Global, Sistema de Eventos e Gamificação.",
"main": "src/server.js",
"private": true,
"author": "Otaku Clash Angola Team",
"license": "Proprietary",

"engines": {
"node": ">=22.0.0",
"npm": ">=10.0.0"
},

"scripts": {
"start": "node src/server.js",
"dev": "nodemon src/server.js",

```
"test": "jest --passWithNoTests --runInBand",
"test:watch": "jest --watch",
"test:coverage": "jest --coverage",

"lint": "eslint src/**/*.js",
"lint:fix": "eslint src/**/*.js --fix",

"format": "prettier --write \"src/**/*.js\"",

"db:migrate": "node src/database/migrate.js",
"db:seed": "node src/database/seed.js",

"cron": "node src/services/cron/CronService.js"
```

},

"keywords": [
"node",
"express",
"supabase",
"postgresql",
"socketio",
"anime",
"otaku",
"quiz",
"battle-royale",
"tournament",
"ranking",
"angola"
],

"dependencies": {
"@supabase/supabase-js": "^2.43.4",
"axios": "^1.7.2",
"bcryptjs": "^2.4.3",
"bullmq": "^5.8.1",
"compression": "^1.7.4",
"cors": "^2.8.5",
"dotenv": "^16.4.5",
"express": "^4.19.2",
"express-rate-limit": "^7.3.1",
"helmet": "^7.1.0",
"http-status": "^1.7.4",
"ioredis": "^5.4.1",
"jsonwebtoken": "^9.0.2",
"morgan": "^1.10.0",
"multer": "^1.4.5-lts.1",
"node-cron": "^3.0.3",
"nodemailer": "^6.9.13",
"pg": "^8.12.0",
"sharp": "^0.33.4",
"socket.io": "^4.7.5",
"swagger-ui-express": "^5.0.1",
"winston": "^3.13.0",
"zod": "^3.23.8"
},

"devDependencies": {
"eslint": "^8.57.0",
"eslint-config-prettier": "^9.1.0",
"eslint-plugin-import": "^2.29.1",
"jest": "^29.7.0",
"nodemon": "^3.1.3",
"prettier": "^3.3.2",
"supertest": "^7.0.0"
},

"jest": {
"testEnvironment": "node",
"coveragePathIgnorePatterns": [
"/node_modules/"
],
"moduleNameMapper": {
"^@/(.*)$": "<rootDir>/src/$1"
}
}
}
